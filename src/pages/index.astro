  <script>
    (function () {
      const banner = document.getElementById('quick-audit-banner');
      const closeBtn = document.getElementById('quick-audit-close');
      if (!banner || !closeBtn) return;

      const STORAGE_KEY = 'qa-banner-dismissed';
      let shown = false;

      function showBanner() {
        if (shown || sessionStorage.getItem(STORAGE_KEY) || !banner) return;
        shown = true;
        banner.classList.remove('hidden');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            banner!.classList.remove('translate-y-full');
          });
        });
      }

      function hideBanner() {
        if (!banner) return;
        banner.classList.add('translate-y-full');
        setTimeout(() => banner!.classList.add('hidden'), 500);
        sessionStorage.setItem(STORAGE_KEY, '1');
      }

      closeBtn.addEventListener('click', hideBanner);

      // Trigger on 60% scroll depth
      function onScroll() {
        const scrolled = window.scrollY + window.innerHeight;
        const total = document.documentElement.scrollHeight;
        if (scrolled / total >= 0.6) {
          showBanner();
          window.removeEventListener('scroll', onScroll);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });

      // Also trigger on mouseleave (desktop exit intent)
      document.documentElement.addEventListener('mouseleave', (e) => {
        if ((e as MouseEvent).clientY <= 0) showBanner();
      });

      // Quick-Check form submission
      const auditForm = document.getElementById('quick-audit-form') as HTMLFormElement | null;
      const auditEmail = document.getElementById('quick-audit-email') as HTMLInputElement | null;
      const auditSuccess = document.getElementById('quick-audit-success');
      const auditError = document.getElementById('quick-audit-error');
      
      if (auditForm && auditEmail) {
        auditForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = auditEmail.value.trim();
          if (!email || !auditEmail.checkValidity()) {
            auditEmail.focus();
            return;
          }
          
          const submitBtn = auditForm.querySelector('button[type="submit"]') as HTMLButtonElement;
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sende\u2026';
          }
          
          try {
            const res = await fetch('https://n8n.dynamics-tim.dev/webhook/quick-check', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, source: window.location.href, timestamp: new Date().toISOString() })
            });
            
            if (res.ok) {
              if (auditSuccess) auditSuccess.classList.remove('hidden');
              if (auditError) auditError.classList.add('hidden');
              auditEmail.value = '';
              auditEmail.disabled = true;
              if (submitBtn) submitBtn.style.display = 'none';
              setTimeout(() => hideBanner(), 3000);
            } else {
              throw new Error('Request failed');
            }
          } catch {
            if (auditError) auditError.classList.remove('hidden');
            if (auditSuccess) auditSuccess.classList.add('hidden');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Quick-Check anfordern';
            }
          }
        });
      }
    })();
  </script>

