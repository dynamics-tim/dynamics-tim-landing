  <script>
    (function () {
      const answers: Record<string, string> = {};
      const btns = document.querySelectorAll<HTMLButtonElement>('.quiz-btn');
      const resultEl = document.getElementById('quiz-result');
      const resultText = document.getElementById('quiz-result-text');
      const resultLink = document.getElementById('quiz-result-link') as HTMLAnchorElement | null;

      function getRecommendation() {
        const q1 = answers['1'], q2 = answers['2'], q3 = answers['3'];
        if (q1 === 'unknown' || q2 === 'clarity') {
          return {
            title: 'Audit & Strategie',
            badge: 'Schnelleinstieg · 1–2 Wochen',
            tagline: 'Du bekommst Klarheit — nicht nur Folien.',
            text: 'Ich analysiere deine aktuelle Dynamics 365 Landschaft und liefere dir einen priorisierten Aktionsplan mit Quick Wins und Roadmap — bevor du in Umsetzung investierst.',
            href: '#audit'
          };
        }
        if (q2 === 'features' || q3 === 'existing') {
          return {
            title: 'Embedded Developer',
            badge: 'Laufend · Sprint-basiert',
            tagline: 'Senior-Kraft ins Team — ohne Overhead.',
            text: 'Du bekommst sofort Senior-Kapazität in deinen Sprint-Prozess integriert — Features, Plugins, Integrationen und Tests im Sprint-Rhythmus.',
            href: '#embedded'
          };
        }
        return {
          title: 'Full Package: Audit → Enablement',
          badge: 'End-to-End · 3–4 Monate',
          tagline: 'Einmal richtig machen. Dauerhaft wirken.',
          text: 'Vom Audit über Umsetzung bis zur Team-Übergabe — dein Team kann am Ende eigenständig releasen und weiterentwickeln.',
          href: '#fullpackage'
        };
      }

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          const q = btn.dataset.q!;
          const v = btn.dataset.v!;
          answers[q] = v;
          // Highlight selected
          document.querySelectorAll<HTMLButtonElement>(`.quiz-btn[data-q="${q}"]`).forEach(b => {
            b.classList.remove('border-brand-400', 'text-brand-600', 'bg-brand-50');
          });
          btn.classList.add('border-brand-400', 'text-brand-600', 'bg-brand-50');
          // Show result when all 3 answered
          if (Object.keys(answers).length === 3 && resultEl && resultText) {
            const rec = getRecommendation();
            const resultTitle = document.getElementById('quiz-result-title');
            const resultBadge = document.getElementById('quiz-result-badge');
            const resultTagline = document.getElementById('quiz-result-tagline');
            resultText.textContent = rec.text;
            if (resultTitle) resultTitle.textContent = rec.title;
            if (resultBadge) resultBadge.textContent = rec.badge;
            if (resultTagline) resultTagline.textContent = '"' + rec.tagline + '"';
            if (resultLink) resultLink.href = rec.href;
            resultEl.classList.remove('hidden');
            // Slide-up animation
            const card = resultEl.querySelector('.quiz-result-card') as HTMLElement | null;
            if (card) {
              card.style.opacity = '0';
              card.style.transform = 'translateY(20px)';
              requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                  card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                  card.style.opacity = '1';
                  card.style.transform = 'translateY(0)';
                });
              });
            }
            resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
        });
      });
    })();
  </script>

